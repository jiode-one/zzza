{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run zzza Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"],
      "outFiles": ["${workspaceFolder}/extensions/vscode/dist/**/*.js"]
    }
  ]
}