{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "zzza-web",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-18",
  "workers_dev": true,

  "assets": {
    "directory": "../apps/web/zzza",
    "binding": "ASSETS"
  },

  "routes": [
    {
      "pattern": "zzza.online/*",
      "custom_domain": true
    }
  ]
}